{
  "name": "mkm-cypress",
  "version": "1.0.0",
  "description": "Este é um projeto de teste da plataforma que utiliza Cypress para validar tanto front-end quanto algumas funcionalidades de back-end, facilitando a localização e correção de possíveis erros.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "cypress open",
    "teste": "cypress run --record --parallel --key $CYPRESS_RECORD_KEY",
    "spec": "cypress run --spec",
    "lint": "eslint .",
    "prepare": "husky install",
    "test:unit:ci": "jest --ci --reporters=default --reporters=jest-junit",
    "start": "node server.js",
    "cy:run": "cypress run", 
    "test:prod": "cypress run --config baseUrl=https://portal.mkom.tec.br/",
    "test:beta": "cypress run --config baseUrl=https://beta.mkom.tec.br/",
    "cy:parallel": "cypress-parallel -s 'cypress run --spec \"cypress/e2e/Cypressjoao/**/*.cy.js\"' -t 2",
    "start:ci": "node API/server.js"
  },
  "keywords": [],
  "author": "Joao Victor <joaovictornunessilva12345@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "axios": "1.7.3",
    "cypress-parallel": "^0.14.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.4.1",
    "mocha": "^10.5.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@testing-library/cypress": "^10.0.2",
    "commitizen": "^4.3.0",
    "cypress": "^13.13.2",
    "cypress-file-upload": "^5.0.8",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-multi-reporters": "^1.5.0",
    "cypress-real-events": "^1.12.0",
    "cypress-split": "^1.24.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.4",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4"
  },
  "repository": "git@github.com:Joao848846/mkm-cypress.git",
  "resolutions": {
    "fast-xml-parser": "4.4.1"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
